html
  head    
    title Stock Control System
    //- Bootstrap CSS
    link(rel='stylesheet', href='https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css')
    //- Bootstrap Icons
    link(rel='stylesheet', href='https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css')
    link(rel='stylesheet', href='/styles.css')
  body
    nav(class="navbar navbar-expand-lg navbar-custom")
      .container-fluid
        .nav-left
          a(class="navbar-brand" href="#") Stock Inventory
        
        .nav-center
          a(class="nav-link active" aria-current="page" href="#") Home
          a(class="nav-link" href="#") Add Product
          a(class="nav-link" href="#") Summary
          a(class="nav-link" href="#") About Us 

        .nav-right
          form(class="search-form" action="/search" method="get")
            .search-wrapper
              i(class="bi bi-search search-icon-left")
              input(class="search-input" type="search" name="query" placeholder="Search Products...")
              button(class="search-btn" type="submit")
                i(class="bi bi-arrow-right")

    

    //- Sort options
    form(action="/sort" method="get")
      select(name="sortBy" onchange="this.form.submit()")
        option(value="name" selected=sortBy === 'name') Sort by Name
        option(value="price" selected=sortBy === 'price') Sort by Price
      
    //- Add new product form
    form(action="/create" method="post")
      label(for="id") ID:
      input(type="text" id="id" name="id" required)
      br
      label(for="name") Name:
      input(type="text" id="name" name="name" required)
      br
      label(for="price") Price:
      input(type="number" id="price" name="price" step="0.01" required)
      br
      label(for="quantity") Quantity:
      input(type="number" id="quantity" name="quantity" required)
      br
      label(for="type") Type:
      select(id="type" name="type" required)
        option(value="") Select a type
        option(value="clothing") Clothing
        option(value="electronic") Electronic
      br
      //- Conditional fields for clothing and electronics
      div(id="clothingFields" style="display: none;")
        label(for="size") Size:
        input(type="text" id="size" name="size")
        br
        label(for="material") Material:
        input(type="text" id="material" name="material")
      div(id="electronicFields" style="display: none;")
        label(for="brand") Brand:
        input(type="text" id="brand" name="brand")
        br
        label(for="warranty") Warranty:
        input(type="text" id="warranty" name="warranty")
      br
      button(type="submit") Add Product

    //- Display products
    table
      thead
        tr
          th ID
          th Name
          th Price
          th Quantity
          th Type
          th Actions
      tbody
        each product in products
          tr
            td= product.id
            td= product.name
            td= product.price
            td= product.quantity
            td= product.type 
            td
              a(href=`/details/${product.id}`) View Details
              form(action=`/delete/${product.id}` method="post" style="display:inline;")
                input(type="hidden" name="_method" value="DELETE")
                button(type="submit") Delete

    //- JavaScript for conditional fields
    script.
      const typeSelect = document.getElementById('type');
      const clothingFields = document.getElementById('clothingFields');
      const electronicFields = document.getElementById('electronicFields');

      function updateFields() {
        if (typeSelect.value === 'clothing') {
          clothingFields.style.display = 'block';
          electronicFields.style.display = 'none';
        } else if (typeSelect.value === 'electronic') {
          clothingFields.style.display = 'none';
          electronicFields.style.display = 'block';
        } else {
          clothingFields.style.display = 'none';
          electronicFields.style.display = 'none';
        }
      }

      typeSelect.addEventListener('change', updateFields);
      
      // Initialize fields on page load
      updateFields();
