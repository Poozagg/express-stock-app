extends pageLayout

block content
    //- Sort and Filter controls on the same line
    .controls-row
      if !(type || minPrice || maxPrice || lowStock)
        form(action="/sort" method="get" class="d-flex gap-2 align-items-center")
          select(name="sortBy" class="form-select form-select-sm" style="width: auto;" onchange="this.form.submit()" )
            option(value="" disabled selected=!sortOrder) Sort by
            option(value="name" selected=sortBy === 'name') Sort by Name
            option(value="pricePerItem" selected=sortBy === 'pricePerItem') Sort by Price Per Item
            option(value="quantity" selected=sortBy === 'quantity') Sort by Quantity
            option(value="type" selected=sortBy === 'type') Sort by Type
          if sortBy
            select(name="sortOrder" class="form-select form-select-sm" style="width: auto;" onchange="this.form.submit()")
              option(value="asc" selected=(sortOrder === 'asc')) Asc
              option(value="desc" selected=(sortOrder === 'desc')) Desc

      if type || minPrice || maxPrice || lowStock
        form(action="/filter" method="get" class="d-flex gap-2 align-items-center")
          if type
            input(type="hidden" name="type" value=type)
          if minPrice
            input(type="hidden" name="minPrice" value=minPrice)
          if maxPrice
            input(type="hidden" name="maxPrice" value=maxPrice)
          if lowStock
            input(type="hidden" name="lowStock" value=lowStock)
          select(name="sortBy" class="form-select form-select-sm" style="width: auto;" onchange="this.form.submit()")
            option(value="" disabled selected=!sortBy) Sort filtered results
            option(value="name" selected=sortBy === 'name') Sort by Name
            option(value="pricePerItem" selected=sortBy === 'pricePerItem') Sort by Price Per Item
            option(value="quantity" selected=sortBy === 'quantity') Sort by Quantity
            option(value="type" selected=sortBy === 'type') Sort by Type
          if sortBy
            select(name="sortOrder" class="form-select form-select-sm" style="width: auto;" onchange="this.form.submit()")
              option(value="asc" selected=(sortOrder === 'asc')) Asc
              option(value="desc" selected=(sortOrder === 'desc')) Desc

      button(type="button" class="btn btn-primary btn-sm" data-bs-toggle="modal" data-bs-target="#filterModal")
        i(class="bi bi-funnel")
        |  Filter

      if type || minPrice || maxPrice || lowStock
        a(href="/" class="btn btn-outline-secondary btn-sm") Clear Filters

    //- Bootstrap Modal
    .modal.fade#filterModal(tabindex="-1" aria-labelledby="filterModalLabel" aria-hidden="true")
      .modal-dialog
        .modal-content
          .modal-header
            h5.modal-title#filterModalLabel Filter Products
            button(type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close")
          form(action="/filter" method="get")
            .modal-body
              //- Type Filter
              .mb-3
                label(for="typeFilter" class="form-label") Type
                select(name="type" id="typeFilter" class="form-select")
                  option(value="" selected=!type) All Types
                  option(value="clothing" selected=type === 'clothing') Clothing
                  option(value="electronic" selected=type === 'electronic') Electronics
                  option(value="book" selected=type === 'book') Books
                  option(value="grocery" selected=type === 'grocery') Groceries
                  option(value="toy" selected=type === 'toy') Toys
              
              //- Price Range
              .mb-3
                label(class="form-label") Price Range
                .d-flex.gap-2.align-items-center
                  input(type="number" name="minPrice" placeholder="Min £" value=minPrice class="form-control" step="0.01")
                  span to
                  input(type="number" name="maxPrice" placeholder="Max £" value=maxPrice class="form-control" step="0.01")
              
              //- Low Stock
              .mb-3.form-check
                input(type="checkbox" name="lowStock" value="true" checked=(lowStock === 'true') class="form-check-input" id="lowStockFilter")
                label(for="lowStockFilter" class="form-check-label") Show Low Stock Only (< 10)
            
            .modal-footer
              button(type="button" class="btn btn-secondary" data-bs-dismiss="modal") Cancel
              a(href="/" class="btn btn-outline-secondary") Clear
              button(type="submit" class="btn btn-primary") Apply Filters
        
    br
    br
    //- Display products
    table
      thead
        tr
          th ID
          th Name
          th Price Per Item
          th Quantity
          th Type
          th Actions
      tbody
        each product in products
          tr
            td= product.id
            td= product.name
            td= product.pricePerItem
            td= product.quantity
            td= product.type 
            td
              a(href=`/details/${product.id}`) View Details
              a(href=`/update/${product.id}` class="btn-icon" title="Update Product Details") 
                i(class="bi bi-pencil-square")
              form(action=`/delete/${product.id}` method="post" style="display:inline;")
                input(type="hidden" name="_method" value="DELETE")
                button(type="submit" title="Delete Product" class="btn-icon")  
                  i(class="bi bi-trash")
            
                
